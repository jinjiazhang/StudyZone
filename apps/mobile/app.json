{
  "expo": {
    "name": "StudyZone",
    "slug": "studyzone",
    "scheme": "studyzone",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.studyzone.app"
    },
    "android": {
      "package": "dev.studyzone.app"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000"
    }
  }
}
