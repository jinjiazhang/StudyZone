# Override the API endpoint per-developer.
# When testing on a real device, replace localhost with your machine's LAN IP
# so the phone can reach the API server.
#
# 1. Copy this file to apps/mobile/.env.local
# 2. Replace the IP with `ipconfig getifaddr en0` (macOS) / `hostname -I` (Linux) output
# 3. Restart `pnpm dev:mobile` so Expo picks up the new value

EXPO_PUBLIC_API_URL=http://192.168.1.10:4000

# Origin where static assets (textbook covers, exercise images) are hosted.
# These are stored as root-relative paths like `/assets/cover/...` and live
# in the web app's `public/` folder. On mobile we must turn them into absolute
# URLs, so set this to the web app origin reachable from the device.
# When testing on a real device, replace localhost with your machine's LAN IP.
EXPO_PUBLIC_ASSET_BASE_URL=http://192.168.1.10:3000
