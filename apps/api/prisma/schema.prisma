// StudyZone — main database schema.
// One file for simplicity; split into separate files via prismaSchemaFolder
// preview feature later if it grows further.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Account
// =============================================================================

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  nickname         String
  avatarUrl        String?
  locale           String   @default("zh-CN")
  timezone         String   @default("Asia/Shanghai")
  dailyGoalMinutes Int      @default(10)
  status           String   @default("active") // active | suspended | deleted
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  identities        AuthIdentity[]
  devices           Device[]
  refreshTokens     RefreshToken[]
  enrollments       Enrollment[]
  lessonProgress    UserLessonProgress[]
  sessions          LearningSession[]
  wallet            UserWallet?
  streak            StreakRecord?
  xpLedger          XPLedger[]
  achievements      UserAchievement[]
  questProgress     UserQuestProgress[]
  friendshipsA      Friendship[]         @relation("friendshipUser")
  friendshipsB      Friendship[]         @relation("friendshipFriend")
  leagueMemberships LeaderboardEntry[]
  leagueHistory     LeagueHistory[]
  subscriptions     Subscription[]
  notifications     Notification[]
  srsCards          SrsCard[]

  @@index([status])
  @@index([createdAt])
}

model AuthIdentity {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  provider    String // google | apple | wechat | github
  providerUid String
  createdAt   DateTime @default(now())

  @@unique([provider, providerUid])
  @@index([userId])
}

model Device {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  platform     String // ios | android | web
  pushToken    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([pushToken])
}

model RefreshToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =============================================================================
// Curriculum
// =============================================================================

model Subject {
  id      String   @id @default(cuid())
  code    String   @unique // english | math | music
  name    String
  icon    String
  color   String
  order   Int      @default(0)
  courses Course[]

  @@index([order])
}

model Course {
  id            String   @id @default(cuid())
  subject       Subject  @relation(fields: [subjectId], references: [id])
  subjectId     String
  fromLocale    String // user's UI language, e.g. zh-CN
  toLocale      String // language being learned, e.g. en-US (math uses "math")
  name          String
  description   String
  coverImageUrl String   @default("")
  version       Int      @default(1)
  status        String   @default("published") // draft | beta | published
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  units       Unit[]
  enrollments Enrollment[]

  @@unique([subjectId, fromLocale, toLocale])
  @@index([status])
}

model Unit {
  id         String @id @default(cuid())
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId   String
  orderIndex Int
  title      String
  themeColor String @default("#3FB984")

  lessons Lesson[]

  @@unique([courseId, orderIndex])
}

model Lesson {
  id            String @id @default(cuid())
  unit          Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId        String
  orderIndex    Int
  title         String
  icon          String @default("")
  exerciseCount Int    @default(8) // target count (server may pick subset)

  exercises    LessonExercise[]
  sessions     LearningSession[]
  userProgress UserLessonProgress[]

  @@unique([unitId, orderIndex])
}

model Exercise {
  id         String   @id @default(cuid())
  type       String
  prompt     Json
  answer     Json
  difficulty Int      @default(1)
  audioUrl   String?
  imageUrl   String?
  createdAt  DateTime @default(now())

  lessons  LessonExercise[]
  attempts ExerciseAttempt[]
  srsCards SrsCard[]
}

// Many-to-many: an exercise can be reused across lessons.
model LessonExercise {
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId   String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  orderIndex Int

  @@id([lessonId, exerciseId])
  @@index([lessonId, orderIndex])
}

// =============================================================================
// Learning state
// =============================================================================

model Enrollment {
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId        String
  currentUnitId   String?
  currentLessonId String?
  xpInCourse      Int      @default(0)
  enrolledAt      DateTime @default(now())
  lastActiveAt    DateTime @default(now())

  @@id([userId, courseId])
  @@index([userId])
}

model UserLessonProgress {
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String
  completed Boolean  @default(false)
  bestScore Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([userId, lessonId])
  @@index([userId])
}

model LearningSession {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  lesson        Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId      String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  correctCount  Int       @default(0)
  totalCount    Int       @default(0)
  xpGained      Int       @default(0)
  heartsUsed    Int       @default(0)
  outcome       String? // pass | fail | abandoned
  exerciseQueue Json // ordered list of exerciseIds picked for this session

  attempts ExerciseAttempt[]

  @@index([userId])
  @@index([startedAt])
}

model ExerciseAttempt {
  id         String          @id @default(cuid())
  session    LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId String
  userAnswer Json
  isCorrect  Boolean
  responseMs Int             @default(0)
  createdAt  DateTime        @default(now())

  @@index([sessionId])
}

model SrsCard {
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  exercise     Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId   String
  intervalDays Int      @default(0)
  ease         Float    @default(2.5)
  streakOk     Int      @default(0)
  dueAt        DateTime @default(now())

  @@id([userId, exerciseId])
  @@index([userId, dueAt])
}

// =============================================================================
// Gamification
// =============================================================================

model UserWallet {
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String   @id
  gems          Int      @default(50)
  hearts        Int      @default(5)
  maxHearts     Int      @default(5)
  streakFreezes Int      @default(0)
  xpTotal       Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model StreakRecord {
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String   @id
  currentStreak       Int      @default(0)
  longestStreak       Int      @default(0)
  lastActiveLocalDate String? // YYYY-MM-DD in user's tz
  updatedAt           DateTime @updatedAt
}

model XPLedger {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  delta     Int
  reason    String
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Achievement {
  id          String @id @default(cuid())
  code        String @unique
  title       String
  description String
  icon        String
  threshold   Int
  category    String // streak | xp | skill_complete | social

  earned UserAchievement[]
}

model UserAchievement {
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId String
  earnedAt      DateTime    @default(now())

  @@id([userId, achievementId])
  @@index([userId])
}

model DailyQuest {
  id          String  @id @default(cuid())
  code        String  @unique
  title       String
  targetValue Int
  xpReward    Int
  gemsReward  Int
  active      Boolean @default(true)

  progress UserQuestProgress[]
}

model UserQuestProgress {
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  quest        DailyQuest @relation(fields: [questId], references: [id], onDelete: Cascade)
  questId      String
  date         String // YYYY-MM-DD
  currentValue Int        @default(0)
  completedAt  DateTime?

  @@id([userId, questId, date])
  @@index([userId, date])
}

// =============================================================================
// Social
// =============================================================================

model Friendship {
  user      User     @relation("friendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  friend    User     @relation("friendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)
  friendId  String
  status    String   @default("pending") // pending | accepted | blocked
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, friendId])
  @@index([friendId])
  @@index([status])
}

model LeagueGroup {
  id        String    @id @default(cuid())
  tier      String // bronze | silver | gold | ...
  weekStart DateTime // Monday 00:00 UTC of the league week
  capacity  Int       @default(30) // max players in this group
  status    String    @default("active") // active | settled
  settledAt DateTime?

  entries LeaderboardEntry[]

  @@index([weekStart, tier, status])
}

model LeaderboardEntry {
  group     LeagueGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  weeklyXp  Int         @default(0)
  rank      Int         @default(0)
  joinedAt  DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@id([groupId, userId])
  @@index([groupId, weeklyXp])
  @@index([userId])
}

// One row per user per settled league week — the source of truth for a
// player's league history, current tier, and promotion/relegation streaks.
model LeagueHistory {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  weekStart   DateTime
  tier        String // tier the user competed in this week
  finalRank   Int
  weeklyXp    Int
  result      String // promoted | stayed | demoted
  nextTier    String // tier the user lands in next week
  gemsAwarded Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId, createdAt])
}

// =============================================================================
// Billing
// =============================================================================

model Subscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  plan      String // monthly | yearly | family
  provider  String // stripe | apple_iap | google_play | wechat | alipay
  status    String // active | trialing | past_due | canceled
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// =============================================================================
// Notifications
// =============================================================================

model Notification {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
